# Torrent to Telegram Bot Configuration Template

# Get these from https://my.telegram.org
TELEGRAM_API_ID="YOUR_API_ID"
TELEGRAM_API_HASH="YOUR_API_HASH"

# Log in using: node login.js
# This will generate and save the session string and bot token automatically!
TELEGRAM_BOT_TOKEN="YOUR_BOT_TOKEN_FROM_BOTFATHER"
TELEGRAM_SESSION="YOUR_GENERATED_SESSION_STRING"

# File Upload Split Limit in Gigabytes (GB)
# - Set to 2 for Standard user accounts or Bot accounts (Max MTProto limit is 2 GB)
# - Set to 4 for Telegram Premium user accounts (Premium Userbot limit is 4 GB)
UPLOAD_LIMIT_GB="2"

# Temporary directory for torrent downloads
DOWNLOAD_DIR="./downloads"
